Algoritmo Calcular_Velocidad
	//Definir Variables
	Definir velocidad, tiempo, distancia Como Real;
	//Entrada de Datos
	Escribir "Ingrese la distancia recorrida: ";
	leer distancia;
	Escribir "Ingrese el tiempo transcurrido: ";
	leer tiempo;
	// Proceso 
	// Conociendo v= d/t
	velocidad = distancia/tiempo;
	//Salida de Datos
	Mostrar "La velocidad de viaje es: ",velocidad, " m/s";
FinAlgoritmo
