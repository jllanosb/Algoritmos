Algoritmo Verificar_Edad_Sexo
    //Definir Variables
    Definir edad como entero;
    Definir sexo como caracter;
    //Entrada de Datos
    Escribir "Ingrese su edad: ";
    Leer edad;
    Escribir "Ingrese su sexo [F-M]: ";
    Leer sexo;
	//Proceso-Decision
	Si edad>=18 y sexo=='F' Entonces
		Escribir "Es una mujer mayor de edad";
	Fin Si
FinAlgoritmo